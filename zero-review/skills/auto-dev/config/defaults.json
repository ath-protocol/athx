{
  "complexity_levels": ["S", "M", "L", "XL"],
  "required_architecture_sections": [
    "component_breakdown",
    "data_flow",
    "technology_choices",
    "complexity_estimate",
    "test_strategy"
  ],
  "required_impact_analysis_sections": [
    "change_summary",
    "affected_modules",
    "interface_changes",
    "integration_points",
    "risk_assessment",
    "complexity_estimate"
  ],
  "confidence_threshold": "MEDIUM",
  "default_paradigm": "dev/architecture-first",
  "task_types": {
    "dev": "dev/architecture-first",
    "enhancement": "enhancement/delta-design",
    "bugfix": "bugfix/hypothesis-driven",
    "addition": "addition/lightweight"
  },
  "phases_directory": "phases",
  "paradigms_directory": "paradigms",
  "environment": {
    "provider": "docker",
    "default_image": "node:20-bookworm",
    "timeout_seconds": 300,
    "cleanup": "always",
    "container_prefix": "e2e",
    "workdir": "/app"
  },
  "ath_protocol": {
    "version": "0.1",
    "sdk_packages": [
      "@ath-protocol/types",
      "@ath-protocol/client",
      "@ath-protocol/server"
    ],
    "required_verify_phase": true,
    "attestation_algorithm": "ES256",
    "session_max_ttl_seconds": 600,
    "token_default_ttl_seconds": 3600,
    "pkce_method": "S256",
    "contract_path": "contracts/ath-protocol.md"
  }
}
